  "Storage": {
    "Provider": "Local",
    "ContainerName": "uploads",
    "Local": {
      "RootPath": "wwwroot/uploads",
      "BaseUrl": "http://localhost:5285/uploads"
    },
    "Security": {
      "MaxFileSizeBytes": 1048576000000,
      "AllowedExtensions": [
        ".jpg",
        ".jpeg",
        ".png",
        ".ico",
        ".pdf",
        ".txt",
        ".docx",
        ".zip",
        ".7z",
        ".rar"
      ]
    }
  },
  "FileManager": {
    "EnforceQuota": true,
    "MaxTotalBytes": 2147483648,
    "MaxFiles": 0,
    "EnableRetentionChecks": true,
    "MaxFileSizes": {
      ".jpg": 1048576,
      ".jpeg": 1048576,
      ".png": 1048576,
      ".zip": 52428800,
      ".rar": 52428800,
      ".7z": 52428800,
      ".pdf": 10485760
    }
  },
  "GlobalSettings": {
    "Paging": {
      "DefaultPageSize": 20,
      "MaxPageSize": 200
    
    }
  },
  "AuditLogs": {
      "IntegritySampleSize": 10,
      "ErrorAlertThreshold": 10,
      "DeleteAlertThreshold": 30,
      "RoleSwitchAlertThreshold": 10,
      "AppAuditLogsTableName": "[dbo].[AppAuditLogs]",
      "AuditDiffViewerFeatureFlagKey": "Compliance.AuditDiffViewer",
      "AuditHardeningFeatureFlagKey": "Compliance.AuditLogHardening",
      "IntegrityTableName": "[dbo].[AppAuditLogIntegrities]",
      "DiffSourceNone": "none",
      "DiffSourceDisabled": "disabled",
      "DiffSourcePayload": "payload",
      "DiffSourcePreviousLog": "previous_log",
      "DiffSourceSnapshot": "snapshot"
    
  },
  "RateLimit": {
    "EnableGlobalLimiter": false,
    "Global": {
      "PermitLimit": 30,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "AuthenticatedPermitLimit": 180,
      "AuthenticatedWindowSeconds": 60,
      "AuthenticatedQueueLimit": 0
    },
    "ExcludedPathPrefixes": [
      "/hubs",
      "/api/v1/SystemSettings/public",
      "/scalar",
      "/openapi"
    ],
    "Policies": [
      {
        "PolicyName": "auth-login",
        "Algorithm": "FixedWindow",
        "PermitLimit": 10,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      {
        "PolicyName": "auth-register",
        "Algorithm": "FixedWindow",
        "PermitLimit": 5,
        "WindowSeconds": 300,
        "QueueLimit": 0
      },
      {
        "PolicyName": "auth-password-recovery",
        "Algorithm": "FixedWindow",
        "PermitLimit": 5,
        "WindowSeconds": 300,
        "QueueLimit": 0
      },
      {
        "PolicyName": "auth-otp-verification",
        "Algorithm": "FixedWindow",
        "PermitLimit": 15,
        "WindowSeconds": 300,
        "QueueLimit": 0
      },
      {
        "PolicyName": "auth-otp-resend",
        "Algorithm": "FixedWindow",
        "PermitLimit": 3,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      {
        "PolicyName": "auth-token-refresh",
        "Algorithm": "FixedWindow",
        "PermitLimit": 30,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      {
        "PolicyName": "auth-authenticated-sensitive",
        "Algorithm": "FixedWindow",
        "PermitLimit": 10,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    ]
  }
