{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/sampleapp-.log",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "EskineriaLogging": {
    "CorrelationIdHeaderName": "X-Correlation-Id",
    "EnableRequestResponseBodyLogging": true,
    "MaxBodyLogSizeBytes": 102400,
    "MaxHeaderValueLogLength": 100,
    "MaxQueryValueLogLength": 200,
    "MaxQueryStringLogLength": 2000,
    "ExcludedPathPrefixes": [
      "/scalar",
      "/openapi"
    ],
    "MaskedFields": [
      "password",
      "token",
      "secret",
      "apikey"
    ],
    "SensitiveHeaders": [
      "Authorization",
      "Cookie",
      "Set-Cookie"
    ],
    "Kafka": {
      "Enabled": false,
      "BootstrapServers": "localhost:9092",
      "Topic": "eskineria.logs",
      "ClientId": "eskineria-api",
      "SecurityProtocol": "Plaintext",
      "SaslMechanism": "Plain",
      "RestrictedToMinimumLevel": "Information",
      "Environment": {
        "Enabled": true,
        "UseDotEnvFile": true,
        "DotEnvFilePath": ".env",
        "BootstrapServersKey": "ESKINERIA_KAFKA_BOOTSTRAP_SERVERS",
        "UsernameKey": "ESKINERIA_KAFKA_USERNAME",
        "PasswordKey": "ESKINERIA_KAFKA_PASSWORD"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=Aparesk; User Id=sa; Password=aA123456;TrustServerCertificate=true;Connection Timeout=30"
