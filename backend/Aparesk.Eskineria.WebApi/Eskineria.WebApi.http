@Aparesk.Eskineria.WebApi_HostAddress = http://localhost:5285
@apiVersion = 1.0
@accessToken = replace-with-access-token
@productId = replace-with-product-id

GET {{Aparesk.Eskineria.WebApi_HostAddress}}/weatherforecast/
Accept: application/json

###

GET {{Aparesk.Eskineria.WebApi_HostAddress}}/api/v{{apiVersion}}/products?pageNumber=1&pageSize=20&includeArchived=false
Authorization: Bearer {{accessToken}}
Accept: application/json

###

POST {{Aparesk.Eskineria.WebApi_HostAddress}}/api/v{{apiVersion}}/products
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "sku": "PRD-001",
  "name": "Sample Product",
  "description": "Project-specific sample feature record.",
  "price": 249.90,
  "currency": "TRY",
  "stockQuantity": 15,
  "isActive": true
}

###

GET {{Aparesk.Eskineria.WebApi_HostAddress}}/api/v{{apiVersion}}/products/{{productId}}
Authorization: Bearer {{accessToken}}
Accept: application/json

###

GET {{Aparesk.Eskineria.WebApi_HostAddress}}/api/v{{apiVersion}}/products/by-sku/PRD-001
Authorization: Bearer {{accessToken}}
Accept: application/json

###

PUT {{Aparesk.Eskineria.WebApi_HostAddress}}/api/v{{apiVersion}}/products/{{productId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "sku": "PRD-001",
  "name": "Updated Sample Product",
  "description": "Updated description",
  "price": 279.90,
  "currency": "TRY"
}

###

POST {{Aparesk.Eskineria.WebApi_HostAddress}}/api/v{{apiVersion}}/products/{{productId}}/adjust-stock
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "quantityDelta": 5
}

###

POST {{Aparesk.Eskineria.WebApi_HostAddress}}/api/v{{apiVersion}}/products/{{productId}}/deactivate
Authorization: Bearer {{accessToken}}

###

POST {{Aparesk.Eskineria.WebApi_HostAddress}}/api/v{{apiVersion}}/products/{{productId}}/activate
Authorization: Bearer {{accessToken}}

###

POST {{Aparesk.Eskineria.WebApi_HostAddress}}/api/v{{apiVersion}}/products/{{productId}}/archive
Authorization: Bearer {{accessToken}}

###

POST {{Aparesk.Eskineria.WebApi_HostAddress}}/api/v{{apiVersion}}/products/{{productId}}/restore
Authorization: Bearer {{accessToken}}

###

DELETE {{Aparesk.Eskineria.WebApi_HostAddress}}/api/v{{apiVersion}}/products/{{productId}}
Authorization: Bearer {{accessToken}}

###
