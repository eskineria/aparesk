<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <title>{{ PasswordChangedAlertEmailTitle }}</title>
    <style type="text/css" rel="stylesheet" media="all">
        body { width: 100% !important; height: 100%; margin: 0; line-height: 1.4; background-color: #F2F4F6; color: #74787E; -webkit-text-size-adjust: none; font-family: 'Inter', Helvetica, Arial, sans-serif; }
        .email-wrapper { width: 100%; margin: 0; padding: 0; background-color: #F2F4F6; }
        .email-content { width: 100%; margin: 0; padding: 0; }
        .email-masthead { padding: 35px 0 25px 0; text-align: center; }
        .email-masthead_logo { width: 50px; height: 50px; background-color: #f7577e; border-radius: 8px; display: inline-block; vertical-align: middle; }
        .email-masthead_name { font-size: 24px; font-weight: bold; color: #313a46; text-decoration: none; margin-left: 10px; display: inline-block; vertical-align: middle; text-transform: uppercase; letter-spacing: 1px; }
        .email-body { width: 100%; max-width: 600px; margin: 0 auto; padding: 0; border-top: 5px solid #f7577e; border-bottom: 1px solid #EDEFF2; background-color: #FFFFFF; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .email-body_inner { width: 100%; max-width: 600px; margin: 0 auto; padding: 45px; box-sizing: border-box; }
        .content-cell { padding: 0; }
        h1 { margin-top: 0; color: #313a46; font-size: 22px; font-weight: bold; text-align: left; }
        p { margin-top: 0; color: #6c757d; font-size: 16px; line-height: 1.5; text-align: left; }
        .meta-table { width: 100%; border-collapse: collapse; margin: 18px 0 24px 0; }
        .meta-table td { border: 1px solid #EDEFF2; padding: 10px 12px; font-size: 14px; color: #495057; }
        .meta-label { background: #f8f9fa; font-weight: 600; width: 180px; }
        .alert { background-color: #fff4f7; border: 1px solid #ffc7d6; color: #8f2642; padding: 14px; border-radius: 6px; margin: 18px 0; font-size: 14px; }
        .button { background-color: #f7577e; border-top: 10px solid #f7577e; border-right: 18px solid #f7577e; border-bottom: 10px solid #f7577e; border-left: 18px solid #f7577e; display: inline-block; color: #FFF !important; text-decoration: none; border-radius: 4px; box-shadow: 0 2px 3px rgba(0, 0, 0, 0.16); -webkit-text-size-adjust: none; font-weight: 600; text-transform: uppercase; font-size: 14px; letter-spacing: 0.5px; }
        .email-footer { width: 100%; max-width: 600px; margin: 0 auto; padding: 30px; text-align: center; }
        .email-footer p { color: #AEB1B7; font-size: 12px; text-align: center; }
        @media only screen and (max-width: 600px) { .email-body_inner, .email-footer { width: 100% !important; } .meta-label { width: auto; } }
    </style>
</head>
<body>
    <table class="email-wrapper" width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td align="center">
                <table class="email-content" width="100%" max-width="600" cellpadding="0" cellspacing="0" style="max-width: 600px;">
                    <tr>
                        <td class="email-masthead">
                            <div class="email-masthead_logo">
                                <span style="color: white; line-height: 50px; font-size: 24px; font-weight: bold;">E</span>
                            </div>
                            <span class="email-masthead_name">ESKINERIA</span>
                        </td>
                    </tr>
                    <tr>
                        <td class="email-body">
                            <table class="email-body_inner" align="center" width="100%" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td class="content-cell">
                                        <h1>{{ Greeting }}</h1>
                                        <p>{{ PasswordChangedAlertEmailContent }}</p>

                                        <table class="meta-table">
                                            <tr>
                                                <td class="meta-label">{{ SecurityEventTimeLabel }}</td>
                                                <td>{{ EventDateTime }}</td>
                                            </tr>
                                            <tr>
                                                <td class="meta-label">{{ SecurityEventLocationLabel }}</td>
                                                <td>{{ LoginLocation }}</td>
                                            </tr>
                                            <tr>
                                                <td class="meta-label">{{ SecurityEventDeviceLabel }}</td>
                                                <td>{{ DeviceInfo }}</td>
                                            </tr>
                                        </table>

                                        <div class="alert">{{ AccountSecurityActionText }}</div>

                                        <table class="body-action" align="center" width="100%" cellpadding="0" cellspacing="0" style="margin: 24px auto; text-align: center;">
                                            <tr>
                                                <td align="center">
                                                    <a href="{{ AccountSecurityActionLink }}" class="button">{{ AccountSecurityButton }}</a>
                                                </td>
                                            </tr>
                                        </table>

                                        <p style="margin-top: 35px; border-top: 1px solid #EDEFF2; padding-top: 20px; font-weight: bold; color: #6c757d;">
                                            {{ EmailTeam }}
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <table class="email-footer" align="center" width="100%" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td class="content-cell">
                                        <p>&copy; 2026 Eskineria. {{ EmailFooterIgnore }}</p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
